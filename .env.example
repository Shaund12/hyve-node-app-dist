# ============================================================================
# Hyve Validator Dashboard — Environment Configuration
# ============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Edit .env with your actual values (see below)
#   3. NEVER commit .env to git — it contains your private key!
#
# Lines starting with # are comments and are ignored.
# To enable an optional variable, remove the leading # and set the value.
#
# ============================================================================


# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED — You MUST set this before the dashboard can sign transactions
# ══════════════════════════════════════════════════════════════════════════════

# VALIDATOR_PRIVATE_KEY
# ─────────────────────
# Your validator's private key in hexadecimal format.
#
# Format:    64-character hex string (a-f, 0-9)
# Prefix:    Do NOT include "0x" at the beginning
# Example:   a1b2c3d4e5f67890abcdef1234567890abcdef1234567890abcdef1234567890
#
# How to get it:
#   - MetaMask:    Account Details → Export Private Key
#   - Keplr:       Not directly exportable (use mnemonic to derive)
#   - Mnemonic:    Use a BIP39 tool to derive the key from your seed phrase
#   - hyved keys:  hyved keys export validator-operator --unsafe --unarmored-hex
#
# What it does:
#   - On startup, the dashboard imports this key into hyved's local "test" keyring
#   - Used to sign: claim rewards, delegate, compound, redelegate, governance votes
#
# Without it:
#   - The dashboard runs in READ-ONLY mode (all monitoring works, no transactions)
#
# ⚠️  SECURITY: This key controls your validator's funds. Never share it.
#     This file is in .gitignore and should never be committed.
#
VALIDATOR_PRIVATE_KEY=your_64_character_hex_private_key_here


# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Uncomment and change these if your setup differs from defaults
# ══════════════════════════════════════════════════════════════════════════════

# DATABASE_URL
# ────────────
# PostgreSQL connection string for storing metrics history, rewards log, etc.
#
# Format:    postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Default:   postgresql://hyvedash:hyvedash_local_2024@127.0.0.1:5432/hyvedash
#
# If PostgreSQL is not available, the dashboard automatically falls back to
# local JSON files. This works but provides limited history and slower queries.
#
# To set up PostgreSQL:
#   sudo -u postgres psql -c "CREATE USER hyvedash WITH PASSWORD 'your_password';"
#   sudo -u postgres psql -c "CREATE DATABASE hyvedash OWNER hyvedash;"
#
# Then uncomment and update the line below:
# DATABASE_URL=postgresql://hyvedash:your_password@127.0.0.1:5432/hyvedash


# HYVE_NODE_DIR
# ─────────────
# Absolute path to your Hyve node installation directory.
#
# Default:   ~/.config/hyve-node
#
# This directory must contain:
#   bin/hyved         — The validator binary (must be executable)
#   home/             — hyved home directory (config/, data/, keyring-test/)
#   logs/             — Log directory (created automatically if missing)
#
# Only change this if your node is installed somewhere other than the default.
# Replace "your_username" with your actual Linux username.
#
# HYVE_NODE_DIR=/home/your_username/.config/hyve-node


# HYVE_DASH_PORT
# ──────────────
# TCP port the dashboard web server listens on.
#
# Default:   8420
#
# Change this if port 8420 is already in use on your machine.
#
# HYVE_DASH_PORT=8420


# HYVE_DASH_HOST
# ──────────────
# Network interface the dashboard binds to.
#
# Default:   127.0.0.1   (localhost only — only this machine can access it)
# LAN:       0.0.0.0     (all interfaces — other devices on your network can access it)
#
# ⚠️  If you set this to 0.0.0.0, anyone on your local network can reach the
#     login page. Make sure you use a strong password and consider a firewall.
#
# HYVE_DASH_HOST=127.0.0.1
